{
  "realm": "facoffee",
  "enabled": true,
  "registrationEmailAsUsername": true,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "registrationAllowed": false,
  "accessTokenLifespan": 86400,
  "smtpServer": {
    "host": "mailpit",
    "port": "1025",
    "from": "no-reply@facoffee.local",
    "fromDisplayName": "Facoffee",
    "auth": "false",
    "ssl": "false",
    "starttls": "false"
  },
  "users": [
    {
      "username": "facoffee@facom.ufms.br",
      "enabled": true,
      "email": "facoffee@facom.ufms.br",
      "emailVerified": true,
      "firstName": "Facoffee",
      "lastName": "Usuario",
      "realmRoles": [
        "MANAGER"
      ],
      "credentials": [
        {
          "type": "password",
          "value": "facoffee",
          "temporary": false
        }
      ]
    }
  ],
  "clients": [
    {
      "clientId": "facoffee-public",
      "name": "facoffee-public",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "implicitFlowEnabled": false,
      "serviceAccountsEnabled": false,
      "redirectUris": [
        "http://localhost/*",
        "http://auth.facoffee.hsborges.dev/*"
      ],
      "defaultClientScopes": [
        "openid",
        "profile",
        "email",
        "roles",
        "domain-roles",
        "web-origins"
      ],
      "webOrigins": [
        "http://localhost",
        "http://auth.facoffee.hsborges.dev"
      ]
    },
    {
      "clientId": "domain-roles",
      "name": "domain-roles",
      "enabled": true,
      "protocol": "openid-connect",
      "attributes": {
        "display.on.consent.screen": "false",
        "include.in.token.scope": "false"
      },
      "protocolMappers": [
        {
          "name": "realm-roles-to-roles-claim",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "consentRequired": false,
          "config": {
            "access.token.claim": "true",
            "id.token.claim": "true",
            "userinfo.token.claim": "true",
            "claim.name": "roles",
            "jsonType.label": "String",
            "multivalued": "true"
          }
        }
      ]
    },
    {
      "clientId": "facoffee-private",
      "name": "facoffee-private",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "implicitFlowEnabled": false,
      "serviceAccountsEnabled": true,
      "secret": "facoffee-private-secret",
      "redirectUris": [
        "http://localhost/*",
        "http://auth.facoffee.hsborges.dev/*"
      ],
      "defaultClientScopes": [
        "openid",
        "profile",
        "email",
        "roles",
        "domain-roles",
        "web-origins"
      ],
      "webOrigins": [
        "http://localhost",
        "http://auth.facoffee.hsborges.dev"
      ]
    }
  ],
  "roles": {
    "realm": [
      {
        "name": "MANAGER",
        "description": "Papel de gestor do dominio",
        "composite": true,
        "composites": {
          "client": {
            "realm-management": [
              "query-users",
              "view-users",
              "manage-users"
            ]
          }
        }
      },
      {
        "name": "PARTICIPANT",
        "description": "Papel de participante do dominio"
      }
    ]
  }
}
